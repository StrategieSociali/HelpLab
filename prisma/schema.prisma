generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model challenge_participants {
  id           BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  challenge_id BigInt     @db.UnsignedBigInt
  user_id      BigInt     @db.UnsignedBigInt
  joined_at    DateTime   @default(now()) @db.DateTime(0)
  challenges   challenges @relation(fields: [challenge_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cp_ch")
  users        users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cp_us")

  @@unique([challenge_id, user_id], map: "uq_cp")
  @@index([user_id], map: "fk_cp_us")
}

model challenge_scores {
  challenge_id         BigInt     @db.UnsignedBigInt
  user_id              BigInt     @db.UnsignedBigInt
  score                Int        @default(0)
  updated_at           DateTime   @default(now()) @db.DateTime(0)
  verified_tasks_count Int        @default(0)
  last_event_at        DateTime?  @db.DateTime(0)
  challenges           challenges @relation(fields: [challenge_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cs_ch")
  users                users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cs_us")

  @@id([challenge_id, user_id])
  @@index([user_id], map: "fk_cs_us")
  @@index([challenge_id, score], map: "idx_cs_challenge_score")
  @@index([challenge_id, last_event_at], map: "idx_cs_challenge_last_event")
  @@index([user_id], map: "idx_cs_user")
}

model challenge_submissions {
  id                   BigInt                           @id @default(autoincrement()) @db.UnsignedBigInt
  challenge_id         BigInt                           @db.UnsignedBigInt
  user_id              BigInt                           @db.UnsignedBigInt
  reviewer_user_id     BigInt?                          @db.UnsignedBigInt
  task_id              BigInt?                          @db.UnsignedBigInt
  payload_json         Json?
  activity_description String?                          @db.VarChar(500)
  status               challenge_submissions_status     @default(pending)
  visibility           challenge_submissions_visibility @default(participants)
  points_awarded       Int?
  created_at           DateTime                         @default(now()) @db.DateTime(0)
  reviewed_at          DateTime?                        @db.DateTime(0)

  // Relazioni principali
  challenges challenges @relation(fields: [challenge_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_csub_ch")
  users      users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_csub_us")

  // Nuova relazione con i task
  task challenge_tasks? @relation(fields: [task_id], references: [id])

  points_transactions points_transactions[]
  review_audit        review_audit[]

  @@index([user_id], map: "fk_csub_us")
  @@index([challenge_id, created_at], map: "idx_challenge_created")
  @@index([task_id], map: "idx_csub_task") // opzionale ma utile
}

model challenges {
  id                     BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  proposal_uuid          String?                  @db.Char(36)
  slug                   String                   @unique(map: "slug") @db.VarChar(160)
  title                  String                   @db.VarChar(200)
  type                   String                   @default("generic") @db.VarChar(80)
  location               String?                  @db.VarChar(255)
  rules                  String?                  @db.Text
  deadline               DateTime?                @db.Date
  status                 challenges_status        @default(open)
  budget_amount          Decimal?                 @db.Decimal(10, 2)
  budget_currency        String?                  @db.Char(3)
  sponsor_id             BigInt?                  @db.UnsignedBigInt
  judge_user_id          BigInt?                  @db.UnsignedBigInt
  created_by             BigInt?                  @db.UnsignedBigInt
  target_json            Json?
  created_at             DateTime                 @default(now()) @db.DateTime(0)
  updated_at             DateTime                 @default(now()) @db.DateTime(0)
  proposal_id            String?                  @unique(map: "proposal_id") @db.Char(36)
  challenge_participants challenge_participants[]
  challenge_scores       challenge_scores[]
  challenge_submissions  challenge_submissions[]
  challenge_tasks        challenge_tasks[]

  users_challenges_created_byTousers users?                @relation("challenges_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_ch_created_by")
  users                              users?                @relation(fields: [judge_user_id], references: [id], onUpdate: NoAction, map: "fk_ch_judge")
  sponsors                           sponsors?             @relation(fields: [sponsor_id], references: [id], onUpdate: NoAction, map: "fk_ch_sponsor")
  challenge_proposals                challenge_proposals?  @relation(fields: [proposal_id], references: [id], onUpdate: NoAction, map: "fk_chal_proposal")
  points_transactions                points_transactions[]

  @@index([judge_user_id], map: "fk_ch_judge")
  @@index([sponsor_id], map: "fk_ch_sponsor")
  @@index([deadline], map: "idx_deadline")
  @@index([status], map: "idx_status")
  @@index([created_by], map: "idx_created_by")
  @@index([proposal_uuid], map: "idx_ch_proposal_uuid")
  @@index([updated_at], map: "idx_ch_updated")
  @@index([proposal_id], map: "idx_challenges_proposal_id")
}

model learning_modules {
  id                   BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  path_id              BigInt                 @db.UnsignedBigInt
  title                String                 @db.VarChar(200)
  content_url          String?                @db.VarChar(500)
  order_index          Int                    @default(1)
  est_minutes          Int?
  learning_paths       learning_paths         @relation(fields: [path_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_lm_path")
  user_module_progress user_module_progress[]

  @@unique([path_id, order_index], map: "uq_path_order")
}

model learning_paths {
  id                BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  slug              String                @unique(map: "slug") @db.VarChar(160)
  title             String                @db.VarChar(200)
  description       String?               @db.Text
  level             learning_paths_level?
  estimated_minutes Int?
  tags_json         Json?
  published         Boolean               @default(true)
  created_at        DateTime              @default(now()) @db.DateTime(0)
  updated_at        DateTime              @default(now()) @db.DateTime(0)
  learning_modules  learning_modules[]

  @@index([level], map: "idx_level")
}

model sponsors {
  id         BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  name       String       @db.VarChar(180)
  website    String?      @db.VarChar(255)
  challenges challenges[]
}

model user_module_progress {
  user_id          BigInt           @db.UnsignedBigInt
  module_id        BigInt           @db.UnsignedBigInt
  completed_at     DateTime         @default(now()) @db.DateTime(0)
  learning_modules learning_modules @relation(fields: [module_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ump_mod")
  users            users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ump_user")

  @@id([user_id, module_id])
  @@index([module_id], map: "fk_ump_mod")
}

model users {
  id                                      BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  username                                String                   @unique(map: "username") @db.VarChar(80)
  email                                   String?                  @unique(map: "email")
  password_hash                           String?                  @db.VarChar(255)
  role                                    users_role?              @default(user)
  created_at                              DateTime                 @default(now()) @db.DateTime(0)
  challenge_participants                  challenge_participants[]
  challenge_proposals                     challenge_proposals[]
  challenge_scores                        challenge_scores[]
  challenge_submissions                   challenge_submissions[]
  challenges_challenges_created_byTousers challenges[]             @relation("challenges_created_byTousers")
  challenges                              challenges[]
  points_transactions                     points_transactions[]
  review_audit                            review_audit[]
  user_module_progress                    user_module_progress[]
}

model form_submissions {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name           String   @db.VarChar(200)
  email          String   @db.VarChar(255)
  interests_json Json?
  newsletter     Boolean  @default(false)
  ip             String?  @db.VarChar(45)
  ua             String?  @db.VarChar(255)
  created_at     DateTime @default(now()) @db.DateTime(0)

  @@index([email], map: "idx_email")
}

model challenge_proposals {
  id                       String                  @id @default(uuid()) @db.Char(36)
  user_id                  BigInt?                 @db.UnsignedBigInt
  title                    String                  @db.VarChar(200)
  description              String?                 @db.Text
  impact_type              String?                 @db.VarChar(80)
  start_date               DateTime?               @db.Date
  deadline                 DateTime?               @db.Date
  location_address         String?                 @db.VarChar(255)
  location_geo             Json?
  target                   Json?
  tasks                    Json?
  visibility_options       Json?
  co2e_estimate_kg         Decimal?                @db.Decimal(12, 3)
  difficulty               Difficulty?
  complexity_notes         String?                 @db.VarChar(255)
  sponsor_interest         Boolean                 @default(false)
  sponsor_pitch            String?                 @db.VarChar(255)
  sponsor_budget_requested Int?
  terms_consent            Boolean                 @default(false)
  status                   ChallengeProposalStatus @default(pending_review)
  challenge_id             BigInt?                 @db.UnsignedBigInt
  approved_at              DateTime?               @db.DateTime(0)
  created_at               DateTime                @default(now()) @db.DateTime(0)
  updated_at               DateTime                @default(now()) @db.DateTime(0)
  users                    users?                  @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_cp_user")
  challenges               challenges?

  @@index([user_id], map: "idx_cp_user")
  @@index([status], map: "idx_cp_status")
  @@index([challenge_id], map: "idx_cp_challenge_id")
  @@index([status, created_at], map: "idx_cp_status_created")
}

model review_audit {
  id                    BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  submission_id         BigInt                @db.UnsignedBigInt
  reviewer_user_id      BigInt                @db.UnsignedBigInt
  action                review_audit_action
  points_awarded        Int?
  note                  String?               @db.VarChar(255)
  created_at            DateTime              @default(now()) @db.DateTime(0)
  users                 users                 @relation(fields: [reviewer_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_audit_reviewer")
  challenge_submissions challenge_submissions @relation(fields: [submission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_audit_submission")

  @@index([reviewer_user_id], map: "reviewer_user_id")
  @@index([submission_id], map: "submission_id")
}

model points_transactions {
  id                     String                @id @db.VarChar(50)
  user_id                BigInt                @db.UnsignedBigInt
  challenge_id           BigInt                @db.UnsignedBigInt
  submission_id          BigInt                @db.UnsignedBigInt
  event                  String                @db.VarChar(80)
  delta                  Int
  meta_json              Json?
  version                String                @default("1.0") @db.VarChar(10)
  created_at             DateTime              @default(now()) @db.DateTime(0)
  auto_base_points       Int?                  @default(0)
  judge_points           Int?                  @default(0)
  final_points           Int?                  @default(0)
  consistency_bonus_pct  Float?                @default(0)
  repetition_penalty_pct Float?                @default(0)
  improvement_bonus_pct  Float?                @default(0)
  scoring_config_version String?               @default("1.0")
  challenges             challenges            @relation(fields: [challenge_id], references: [id], onDelete: Cascade, map: "fk_pt_challenge")
  submissions            challenge_submissions @relation(fields: [submission_id], references: [id], onDelete: Cascade, map: "fk_pt_submission")
  users                  users                 @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_pt_user")

  @@unique([submission_id, event], map: "uq_pt_submission_event")
  @@index([challenge_id, created_at], map: "idx_pt_challenge_created")
  @@index([user_id, challenge_id], map: "idx_pt_user_challenge")
  @@index([event], map: "idx_pt_event")
}

model challenge_tasks {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  challenge_id BigInt   @db.UnsignedBigInt
  title        String   @db.VarChar(200)
  description  String?  @db.Text
  order_index  Int      @default(0)
  created_at   DateTime @default(now()) @db.DateTime(0)

  challenges            challenges              @relation(fields: [challenge_id], references: [id], onDelete: Cascade, map: "fk_task_challenge")
  challenge_submissions challenge_submissions[]

  @@unique([challenge_id, order_index], map: "uq_task_challenge_order")
  @@index([challenge_id], map: "idx_task_challenge")
}

enum users_role {
  user
  judge
  admin
}

enum challenge_submissions_status {
  pending
  approved
  rejected
}

enum learning_paths_level {
  beginner
  intermediate
  advanced
}

enum challenges_status {
  open
  in_review
  closed
}

enum ChallengeProposalStatus {
  pending_review
  approved
  rejected
}

enum Difficulty {
  low
  medium
  high
}

enum review_audit_action {
  approve
  reject
}

enum challenge_submissions_visibility {
  private
  participants
  public
}
