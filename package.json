{
  "name": "helplab-backend",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/server.ts",
    "build": "tsc",
    "start": "node build/server.js",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "test": "vitest run --reporter=basic",
    "test:watch": "vitest",
    "test:e2e": "vitest run src/test/**/*.test.ts --reporter=basic"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@prisma/client": "^5.16.1",
    "argon2": "^0.44.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.5.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.5",
    "pino": "^9.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.12",
    "@types/supertest": "^2.0.16",
    "cross-env": "^7.0.3",
    "prisma": "^5.16.1",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.15.7",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  }
}
